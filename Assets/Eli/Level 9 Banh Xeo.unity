      m_Calls: []
  m_text: "B\xE1nh x\xE8o is a Vietnamese pancake made from rice flour, turmeric,
    and coconut milk. The name comes from the sizzling sound made while cooking the
    batter in a hot pan. It is commonly filled with shrimp, pork, and bean sprouts,
    then eaten with vegetables. B\xE1nh x\xE8o is popular in Southern and Central
    Vietnam as a sharing dish for family meals.  \n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: f6b83f304dc3a98448bbbbe575dcc972, type: 2}

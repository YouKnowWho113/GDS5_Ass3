  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7e99d2aa6db43f2478d3198a0ca05313, type: 3}
  m_Name: "Level 5 Aftertaste \u2014 2,5-3,5 Rating"
  m_EditorClassIdentifier: 
  dialogueInfo:
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: Sooo? Thoughts?
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: The wrapping was tender.
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: And the sweet-sour balance was decent
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: That sounds good so far
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: But the sauce was too watery
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: And honestly, the presentation could be much better
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: "\u2026Presentation?"
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: If you want your stall to grow bigger, details matter
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: "Heh\u2026 Someone\u2019s starting to sound like a real celebrity critic"
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: Well, professionalism matters
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: "Yeah, right\u2026 professionalism\u2026 right\u2026"
    characterEmotion: 0
    continueCheck: 0

  dialogueInfo:
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "\u2026This taste\u2026"
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: 0b984171a6a6db64e97413486511e156, type: 2}
    charText: Hm?
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "It reminds me of home\u2026"
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: 3d268a191a4d0ed409ac9f560a10877f, type: 2}
    charText: '*The Old Lady smiles softly.

'
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: 0b984171a6a6db64e97413486511e156, type: 2}
    charText: "Food tastes best when it\u2019s made with care"
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: 3d268a191a4d0ed409ac9f560a10877f, type: 2}
    charText: '*I silently looked down

'
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "(monologue) When did I stop loving food\u2026?"
    characterEmotion: 0
    continueCheck: 1

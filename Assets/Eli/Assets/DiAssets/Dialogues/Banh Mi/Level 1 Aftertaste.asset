  dialogueInfo:
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: "So\u2026 how was my signature dish?"
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "Pretty good, I\u2019ll give you that. The savoury from the beef combined
      with the sweetness of the bread"
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: Why are you talking like you are a food reviewer there?
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "Well, I prefer doing it the professional way\u2026"
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "But yes, I\u2019m something of a food critic myself"
    characterEmotion: 0
    continueCheck: 1

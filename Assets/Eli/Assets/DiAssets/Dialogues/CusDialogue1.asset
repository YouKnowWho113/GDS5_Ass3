%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7e99d2aa6db43f2478d3198a0ca05313, type: 3}
  m_Name: CusDialogue1
  m_EditorClassIdentifier: 
  dialogueInfo:
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "Okay\u2026 let me check the manual first. \u201CFeng Shui guidelines
      for bedroom arrangement.\""
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: 'Rule one: the bed must not face the door.'
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: 60a087669dc5ea343ad67744b265baba, type: 2}
    charText: "Hm? No, just put the bed wherever. I\u2019m fine as long as it looks
      nice."
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "Right\u2026 \u201CRule two: all major objects should be placed against
      the wall."
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: 60a087669dc5ea343ad67744b265baba, type: 2}
    charText: "I don\u2019t want everything pushed to the wall. Leave some breathing
      room between the furniture."
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: 'Rule three: no mirror should face the bed.'
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: 60a087669dc5ea343ad67744b265baba, type: 2}
    charText: I actually want the mirror there. It makes the room feel bigger.
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "\u2026That\u2019s not what the manual says. "
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: 60a087669dc5ea343ad67744b265baba, type: 2}
    charText: "I\u2019m the one living here, not the manual."
    characterEmotion: 3
    continueCheck: 1
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: Alright. Let me keep reading.
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: 60a087669dc5ea343ad67744b265baba, type: 2}
    charText: Good. Then listen to what I need too.
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: 60a087669dc5ea343ad67744b265baba, type: 2}
    charText: The TV should directly face the bed.
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "The manual doesn\u2019t mention that as a priority."
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: 60a087669dc5ea343ad67744b265baba, type: 2}
    charText: I am mentioning it now.
    characterEmotion: 3
    continueCheck: 1
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: And leave at least one tile of empty space between every furniture.
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: That may conflict with the wall placement rule.
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: 60a087669dc5ea343ad67744b265baba, type: 2}
    charText: "Then don\u2019t follow the rule too literally."
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: 60a087669dc5ea343ad67744b265baba, type: 2}
    charText: "Also, don\u2019t place anything in front of the window. I want the
      light clear."
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: Noted. Keep the window unobstructed.
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: 60a087669dc5ea343ad67744b265baba, type: 2}
    charText: And do not block the door.
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: That one, at least, agrees with common sense.
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: 60a087669dc5ea343ad67744b265baba, type: 2}
    charText: One more thing. The clock needs to face the bed.
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "The clock facing the bed\u2026 right."
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: 'So just to be clear: the manual says one thing, and you want something
      else.'
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: 60a087669dc5ea343ad67744b265baba, type: 2}
    charText: "Exactly. You\u2019re the designer. Figure out which one matters more."
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "\u2026Understood."
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: 60a087669dc5ea343ad67744b265baba, type: 2}
    charText: "Good. I\u2019ll be watching."
    characterEmotion: 0
    continueCheck: 1

--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7e99d2aa6db43f2478d3198a0ca05313, type: 3}
  m_Name: Family
  m_EditorClassIdentifier: 
  dialogueInfo:
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "I\u2019m starving right now, mom. Is there any food in the fridge?"
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: e262628979374374ca9c78d134499f49, type: 2}
    charText: Here. I have just finished making this. How about you become my first
      reviewer?
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: Sure, mom. Thanks for the food~
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "Munch munch munch\u2026"
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: Wow! This tastes so good! The taste is sweet yet salty but not too
      overwhelming and the textures is-
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: e262628979374374ca9c78d134499f49, type: 2}
    charText: Such an interesting discovery. My son really has what it takes to be
      a food critic there
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "Really? Then I\u2019ll do my best to become THE legendary food critic
      whose name will be heard and admired by all the chefs around the world!"
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: e262628979374374ca9c78d134499f49, type: 2}
    charText: Well then, my legendary food critic, would you like to help me try
      some more food?
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: Yes, mom!
    characterEmotion: 0
    continueCheck: 0

%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7e99d2aa6db43f2478d3198a0ca05313, type: 3}
  m_Name: CheHue_after_sound_scan
  m_EditorClassIdentifier: 
  dialogueInfo:
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "\u201COkay, the sound backs it up too.\u201D"
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "\u201CWhen I tap through it, it has this soft, sticky little sound.\u201D"
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "\u201CNot crunchy, not watery. More like the syrup and beans are holding
      together.\u201D"
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "\u201CThat makes the sweetness feel thicker, like it\u2019s mixed
      into the whole bowl.\u201D"
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: "\u201CHah. You\u2019re really listening to dessert now.\u201D"
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "\u201CYeah, and somehow it\u2019s actually helping.\u201D"
    characterEmotion: 0
    continueCheck: 0

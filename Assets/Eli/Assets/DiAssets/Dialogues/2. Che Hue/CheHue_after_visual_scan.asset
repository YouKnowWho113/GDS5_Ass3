--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7e99d2aa6db43f2478d3198a0ca05313, type: 3}
  m_Name: CheHue_after_visual_scan
  m_EditorClassIdentifier: 
  dialogueInfo:
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "\u201COh, this already looks sweet.\u201D"
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "\u201CThe syrup has that shiny layer on top, and it\u2019s clinging
      around the beans.\u201D"
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "\u201CIt doesn\u2019t look watery. It looks thick enough to carry
      the sweetness properly.\u201D"
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "\u201CJust from looking at it, the main clue is pretty clear.\u201D"
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "\u201CThis Ch\xE8 Hu\u1EBF is probably going hard on sweetness.\u201D"
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: "\u201CYou got all that just from staring at it?\u201D"
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "\u201CNot all of it. But the surface is basically snitching already.\u201D"
    characterEmotion: 0
    continueCheck: 1

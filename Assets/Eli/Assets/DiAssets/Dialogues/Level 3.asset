%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7e99d2aa6db43f2478d3198a0ca05313, type: 3}
  m_Name: Level 3
  m_EditorClassIdentifier: 
  dialogueInfo:
  - character: {fileID: 11400000, guid: 1a5b9bec349684c4fa27f47e4f1c1f8f, type: 2}
    charText: Greetings! Welcome to our restaurant. What would you like to order?
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: e262628979374374ca9c78d134499f49, type: 2}
    charText: Well I heard that-
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: a859c5d308942624ab89559b9c793479, type: 2}
    charText: "Hey! When are you gonna pay this month\u2019s rent, huh?!"
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: a859c5d308942624ab89559b9c793479, type: 2}
    charText: You told me you would have the money in 3 days and that is today!!
      Now, where is it?!
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: 1a5b9bec349684c4fa27f47e4f1c1f8f, type: 2}
    charText: "I\u2019m so sorry. I\u2019m really close to having enough. Probably
      just a few days more and I\u2019ll have the money by then. Please!"
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: a859c5d308942624ab89559b9c793479, type: 2}
    charText: "Fine! Just 3 days. And if you still don\u2019t have it, be prepared
      to pack your crappy diner and get the hell out of my property!"
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: 1a5b9bec349684c4fa27f47e4f1c1f8f, type: 2}
    charText: "Sorry for letting you see that. I hope it doesn\u2019t affect your
      mood."
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: 1a5b9bec349684c4fa27f47e4f1c1f8f, type: 2}
    charText: "I\u2019m the owner of this diner. If you don\u2019t mind staying for
      the meal, I\u2019ll only take half the price of what you want to order."
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "No, no! I can\u2019t do that! Just charge the full price like normal."
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "I\u2019m a food critic, and I want to do my job professionally so
      that my experience can be like everyone else."
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: 1a5b9bec349684c4fa27f47e4f1c1f8f, type: 2}
    charText: 'Fo- Fo- Food critic?! '
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "\u201CAre you done?"
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: "Almost\u2026"
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: Hahahahahahahahahahahahahahahahahahahaha!
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: "Ha\u2026 Haaaa\u2026"
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: "Okay. I\u2019m done."
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: Wow. That was some real laughter you did there.
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: "That\u2019s because you talked like you have had decades of experience!
      You really had me, you know?"
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: Well, we all have to start from somewhere, right
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: True
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: So I chose your vendor to be the starting point of my career.
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "I get to be a food critic and you get free advertisements. That\u2019s
      a win-win situation, don\u2019t you think?"
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: "Alright. You got me. It\u2019s a deal then."
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: "Sooo\u2026. Mr. Professional Food Critic, what should I call you?"
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: "*Name changed*, huh? An \u201Cinteresting\u201D choice for a name
      there."
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: " \u201CWhat? You don\u2019t think it\u2019s good?"
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: "It\u2019s cool. It\u2019s cool. It's up to you to decide after all."
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "Ooh\u2026kay."
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "Oh yeah, I noticed that you don\u2019t just sell B\xE1nh M\xEC, right?"
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: "Yep. I sell Ch\xE8 Hu\u1EBF and-"
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "Sweet! I\u2019ll have one of that as well if you don\u2019t mind."
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: Sure thing, mate. Coming right up.
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: "Oh and be sure to \u201Ccritic\u201D it as well, yeah?"
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: Gotcha.
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: "So\u2026 how was it?"
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: Holy moly! That was so good!
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: The flavours of the mixed beans compliment each other so well that
      I could taste all of them without the feeling like they were fighting each
      other at all.
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: Hahaha!
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: Look at you! You really enjoyed my dessert that much, huh?
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: Of course! How could anyone not enjoy this?
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: Then your review better be good about it.
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: "Otherwise, I\u2019m gonna punch you in the face. Hahaha."
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: Alright! You got it.
    characterEmotion: 0
    continueCheck: 0

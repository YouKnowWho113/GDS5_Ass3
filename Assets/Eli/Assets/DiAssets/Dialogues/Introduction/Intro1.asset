  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7e99d2aa6db43f2478d3198a0ca05313, type: 3}
  m_Name: Intro1
  m_EditorClassIdentifier: 
  dialogueInfo:
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "\u201CI\u2019m starving right now, mom. Is there any food in the fridge?\u201D"
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: e262628979374374ca9c78d134499f49, type: 2}
    charText: "\u201CHere. I have just finished making this. How about you become
      my first reviewer?\u201D"
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "\u201CSure, mom. Thanks for the food~\u201D"
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "\u201CNow, let's treat this like a proper tasting tutorial.\u201D"
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: e262628979374374ca9c78d134499f49, type: 2}
    charText: "\u201CDon\u2019t rush the bite. Look at the steak first.\u201D"
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: e262628979374374ca9c78d134499f49, type: 2}
    charText: 'Tip: use `right click` to reveal what was used on the dish.'
    characterEmotion: 0
    continueCheck: 1

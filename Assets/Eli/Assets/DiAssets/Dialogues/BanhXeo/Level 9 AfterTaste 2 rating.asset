  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7e99d2aa6db43f2478d3198a0ca05313, type: 3}
  m_Name: Level 9 AfterTaste 2 rating
  m_EditorClassIdentifier: 
  dialogueInfo:
  - character: {fileID: 11400000, guid: 66353d41dda40ed4b916194c7b110f3c, type: 2}
    charText: "What did you think of the B\xE1nh X\xE8o?"
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: The crust was too salty
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: And the sauce was watery.
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: "\u2026I understand."
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: No
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: "You don\u2019t"
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 0}
    charText: I turning right looking at Fendory
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: You used to smile when eating food
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: 'You talked about flavors like they made you happy



'
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: And?
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: "Now you just sound like you\u2019re trying to look superior"
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "That\u2019s called professionalism"
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: No
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: "That\u2019s arrogance"
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: 3d268a191a4d0ed409ac9f560a10877f, type: 2}
    charText: '*Silence'
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: When was the last time you actually enjoyed food?
    characterEmotion: 0
    continueCheck: 1

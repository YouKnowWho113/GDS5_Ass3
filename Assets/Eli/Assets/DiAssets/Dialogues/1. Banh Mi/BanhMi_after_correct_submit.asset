  m_Script: {fileID: 11500000, guid: 7e99d2aa6db43f2478d3198a0ca05313, type: 3}
  m_Name: BanhMi_after_correct_submit
  m_EditorClassIdentifier: 
  dialogueInfo:
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: "\u201CSweet, umami, and crispy. Yep, that\u2019s the one.\u201D"
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "\u201CThe beef gives it that deep flavour, the bread keeps it crunchy,
      and the sweetness pulls everything together.\u201D"
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "\u201CIt\u2019s not fancy, but it works because every part has a job.\u201D"
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: "\u201CThat might be the most serious review my b\xE1nh m\xEC has ever
      received.\u201D"
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "\u201CFood doesn\u2019t have to be expensive to be worth paying attention
      to.\u201D"
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "\u201CFair enough. Come back later then. I\u2019ve got other dishes
      that might mess with your head a little more.\u201D"
    characterEmotion: 0
    continueCheck: 1

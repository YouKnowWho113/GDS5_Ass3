%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7e99d2aa6db43f2478d3198a0ca05313, type: 3}
  m_Name: BanhMi_after_table_click
  m_EditorClassIdentifier: 
  dialogueInfo:
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: '"Welcome to my prestige vendor. We have all kinds of food you can
      expect from a vendor."'
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: "\u201CFirst time at my stall? What would you like to have?\""
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: '"I heard that you and your vendor have become popular lately which
      caught my interest."'
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: "\u201CThen they have a good taste. My grilled beef b\xE1nh m\xEC is
      the one they usually come back for.\u201D"
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "\u201CGrilled beef, bread, sauce\u2026 simple on the surface.\u201D"
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: dcbb5bf5c792b71498b2fb1c38ad7fd7, type: 2}
    charText: "\u201CBut if people keep coming back, there is probably something
      hidden in the balance.\u201D"
    characterEmotion: 0
    continueCheck: 1
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: "\u201CYou sound like someone who inspects food instead of just eating
      it.\u201D"
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: "\u201CThat is the plan.\u201D"
    characterEmotion: 0
    continueCheck: 0
  - character: {fileID: 11400000, guid: b3301c203e1570d4baea337fddfeacfa, type: 2}
    charText: "\u201CThen go ahead. Look closely. Listen closely. A good b\xE1nh
      m\xEC tells you more than it says.\u201D"
    characterEmotion: 0
    continueCheck: 1
